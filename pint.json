{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "ordered_imports": {
            "sort_algorithm": "length",
            "imports_order": ["class", "const", "function"]
        },
        "no_unused_imports": true,
        "simplified_if_return": true,
        "array_syntax": {
            "syntax": "short"
        },
        "trailing_comma_in_multiline": {
            "elements": ["arguments", "arrays", "match", "parameters"]
        }
    }
}
