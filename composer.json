{
    "name": "hamoi1/laravel-fib-integration",
    "description": "A Laravel package for integrating with the First Iraqi Bank (FIB) payment gateway, providing seamless payment processing and management.",
    "keywords": [
        "fib",
        "first-iraqi-bank",
        "payment",
        "laravel",
        "iqd",
        "iraq",
        "gateway",
        "integration",
        "package"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Hamoi1",
            "email": "ihama9728@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/cache": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.10",
        "larastan/larastan": "^2.0",
        "pestphp/pest": "^2.0 || ^3.0",
        "pestphp/pest-plugin-laravel": "^2.0 || ^3.0",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Hamoi1\\FibIntegration\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hamoi1\\FibIntegration\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hamoi1\\FibIntegration\\FibServiceProvider"
            ],
            "aliases": {
                "Fib": "Hamoi1\\FibIntegration\\Facades\\Fib"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/pest",
        "lint": "vendor/bin/pint --test",
        "lint:fix": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse",
        "check": [
            "@lint",
            "@analyse",
            "@test"
        ]
    }
}